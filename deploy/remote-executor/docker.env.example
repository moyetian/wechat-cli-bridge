WECHAT_CLI_BRIDGE_REMOTE_EXECUTOR_HOST=0.0.0.0
WECHAT_CLI_BRIDGE_REMOTE_EXECUTOR_PORT=8081
WECHAT_CLI_BRIDGE_REMOTE_EXECUTOR_STORAGE_DIR=/data/research-executor
WECHAT_CLI_BRIDGE_REMOTE_EXECUTOR_API_KEY=replace-with-a-strong-token
WECHAT_CLI_BRIDGE_REMOTE_EXECUTOR_POLL_MS=2000
