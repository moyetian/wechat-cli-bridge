{
  "name": "wechat-cli-bridge",
  "version": "1.4.0",
  "description": "Bridge WeChat ClawBot to multiple CLI agents (iFlow, Codex, Gemini, Claude Code) with context management",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "wechat-cli-bridge": "./bin/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "daemon": "node bin/daemon.js",
    "setup": "ts-node src/setup.ts",
    "clean": "rimraf dist",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "test": "jest"
  },
  "keywords": [
    "wechat",
    "clawbot",
    "cli",
    "agent",
    "iflow",
    "codex",
    "gemini",
    "claude-code",
    "context-engineering"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@types/nodemailer": "^7.0.11",
    "axios": "^1.6.0",
    "chalk": "^4.1.2",
    "commander": "^11.1.0",
    "dotenv": "^16.3.1",
    "fs-extra": "^11.2.0",
    "marked": "^11.1.0",
    "marked-terminal": "^6.0.0",
    "nodemailer": "^8.0.4",
    "ora": "^7.0.1",
    "uuid": "^9.0.1",
    "winston": "^3.11.0",
    "yaml": "^2.3.4"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/jest": "^29.5.0",
    "@types/node": "^20.10.0",
    "@types/uuid": "^9.0.7",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "rimraf": "^5.0.5",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/moyetian/wechat-cli-bridge.git"
  },
  "bugs": {
    "url": "https://github.com/moyetian/wechat-cli-bridge/issues"
  },
  "homepage": "https://github.com/moyetian/wechat-cli-bridge#readme"
}
