{
  "defaultAgent": "iflow",
  "workingDirectory": "~/projects",
  "agents": {
    "iflow": {
      "type": "cli",
      "command": "iflow",
      "args": ["--print"],
      "timeout": 300000,
      "sessionResume": true
    },
    "claude": {
      "type": "cli",
      "command": "claude",
      "args": ["-p", "--dangerously-skip-permissions"],
      "timeout": 300000,
      "sessionResume": true
    },
    "codex": {
      "type": "cli",
      "command": "codex",
      "args": ["exec"],
      "timeout": 300000,
      "sessionResume": true
    },
    "gemini": {
      "type": "cli",
      "command": "gemini",
      "args": ["-p"],
      "timeout": 300000,
      "sessionResume": true
    },
    "openclaw": {
      "type": "http",
      "endpoint": "http://localhost:8080",
      "apiKey": "",
      "model": "main",
      "timeout": 300000
    }
  },
  "context": {
    "maxHistory": 50,
    "summarizeThreshold": 20000
  },
  "permission": {
    "mode": "auto",
    "timeout": 120
  },
  "media": {
    "maxImageSizeMB": 10,
    "maxFileSizeMB": 25
  },
  "mail": {
    "enabled": false,
    "provider": "smtp",
    "from": "bot@example.com",
    "replyTo": "bot@example.com",
    "defaultTo": ["you@example.com"],
    "maxAttachmentSizeMB": 25,
    "smtp": {
      "host": "smtp.example.com",
      "port": 465,
      "secure": true,
      "user": "bot@example.com",
      "pass": "app-password"
    }
  },
  "research": {
    "enabled": false,
    "executor": {
      "backend": "remote_http",
      "maxBudgetUSD": 30,
      "maxRuntimeMinutes": 240,
      "allowNetwork": false,
      "remoteHttp": {
        "endpoint": "http://your-server/research-executor",
        "apiKey": "replace-with-the-same-token"
      },
      "localGpu": {
        "queueDir": "~/.wechat-cli-bridge/projects/research-queue",
        "statusDir": "~/.wechat-cli-bridge/projects/research-queue/status",
        "recoveryDir": "~/.wechat-cli-bridge/projects/research-queue/recovery",
        "pythonBin": "python3"
      }
    }
  }
}
