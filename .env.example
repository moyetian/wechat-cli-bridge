# Environment variables template
# Copy to .env and fill in your values

# iLink API credentials (from WeChat ClawBot setup)
ILINK_BOT_TOKEN=your_bot_token_here
ILINK_ACCOUNT_ID=your_account_id_here
ILINK_BASE_URL=https://ilinkai.weixin.qq.com

# Optional: OpenClaw HTTP gateway
OPENCLAW_GATEWAY_URL=http://localhost:8080
OPENCLAW_GATEWAY_TOKEN=your_openclaw_token

# Optional: remote research executor
WECHAT_CLI_BRIDGE_REMOTE_EXECUTOR_HOST=0.0.0.0
WECHAT_CLI_BRIDGE_REMOTE_EXECUTOR_PORT=8081
WECHAT_CLI_BRIDGE_REMOTE_EXECUTOR_STORAGE_DIR=/var/lib/wechat-cli-bridge/research-executor
WECHAT_CLI_BRIDGE_REMOTE_EXECUTOR_API_KEY=replace-with-a-strong-token
WECHAT_CLI_BRIDGE_REMOTE_EXECUTOR_POLL_MS=2000
WECHAT_CLI_BRIDGE_REMOTE_EXECUTOR_SIMULATE_MS=1500

# Log level (debug, info, warn, error)
LOG_LEVEL=info
